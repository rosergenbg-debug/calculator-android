<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">
    <TextView android:id="@+id/tvExpression"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:paddingHorizontal="24dp" android:paddingTop="48dp" android:paddingBottom="4dp"
        android:textSize="18sp" android:textColor="@color/text_secondary"
        android:gravity="end" android:singleLine="true" android:ellipsize="start"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView android:id="@+id/tvDisplay"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:paddingHorizontal="24dp" android:paddingBottom="16dp"
        android:text="0" android:textSize="64sp" android:textColor="@color/text_primary"
        android:gravity="end" android:singleLine="true" android:ellipsize="start"
        app:layout_constraintTop_toBottomOf="@id/tvExpression"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <ImageButton android:id="@+id/btnBackspace"
        android:layout_width="40dp" android:layout_height="40dp"
        android:layout_marginEnd="20dp" android:layout_marginBottom="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_backspace"
        android:tint="@color/text_secondary"
        android:contentDescription="Backspace"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/tvDisplay"/>
    <View android:id="@+id/divider"
        android:layout_width="0dp" android:layout_height="1dp"
        android:background="@color/divider"
        app:layout_constraintTop_toBottomOf="@id/tvDisplay"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <androidx.gridlayout.widget.GridLayout
        android:id="@+id/gridButtons"
        android:layout_width="0dp" android:layout_height="0dp"
        android:padding="12dp"
        app:columnCount="4" app:rowCount="5"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <Button android:id="@+id/btnClear" style="@style/CalcButton.Secondary" android:text="AC" app:layout_column="0" app:layout_row="0" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
        <Button android:id="@+id/btnSign" style="@style/CalcButton.Secondary" android:text="+/−" app:layout_column="1" app:layout_row="0" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
        <Button android:id="@+id/btnPercent" style="@style/CalcButton.Secondary" android:text="%" app:layout_column="2" app:layout_row="0" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
        <Button android:id="@+id/btnDivide" style="@style/CalcButton.Operator" android:text="÷" app:layout_column="3" app:layout_row="0" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
        <Button android:id="@+id/btn7" style="@style/CalcButton" android:text="7" app:layout_column="0" app:layout_row="1" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
        <Button android:id="@+id/btn8" style="@style/CalcButton" android:text="8" app:layout_column="1" app:layout_row="1" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
        <Button android:id="@+id/btn9" style="@style/CalcButton" android:text="9" app:layout_column="2" app:layout_row="1" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
        <Button android:id="@+id/btnMultiply" style="@style/CalcButton.Operator" android:text="×" app:layout_column="3" app:layout_row="1" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
        <Button android:id="@+id/btn4" style="@style/CalcButton" android:text="4" app:layout_column="0" app:layout_row="2" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
        <Button android:id="@+id/btn5" style="@style/CalcButton" android:text="5" app:layout_column="1" app:layout_row="2" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
        <Button android:id="@+id/btn6" style="@style/CalcButton" android:text="6" app:layout_column="2" app:layout_row="2" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
        <Button android:id="@+id/btnMinus" style="@style/CalcButton.Operator" android:text="−" app:layout_column="3" app:layout_row="2" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
        <Button android:id="@+id/btn1" style="@style/CalcButton" android:text="1" app:layout_column="0" app:layout_row="3" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
        <Button android:id="@+id/btn2" style="@style/CalcButton" android:text="2" app:layout_column="1" app:layout_row="3" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
        <Button android:id="@+id/btn3" style="@style/CalcButton" android:text="3" app:layout_column="2" app:layout_row="3" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
        <Button android:id="@+id/btnPlus" style="@style/CalcButton.Operator" android:text="+" app:layout_column="3" app:layout_row="3" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
        <Button android:id="@+id/btn0" style="@style/CalcButton.Wide" android:text="0" app:layout_column="0" app:layout_row="4" app:layout_columnSpan="2" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
        <Button android:id="@+id/btnDecimal" style="@style/CalcButton" android:text="," app:layout_column="2" app:layout_row="4" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
        <Button android:id="@+id/btnEquals" style="@style/CalcButton.Equals" android:text="=" app:layout_column="3" app:layout_row="4" app:layout_columnWeight="1" app:layout_rowWeight="1" app:layout_gravity="fill"/>
    </androidx.gridlayout.widget.GridLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
