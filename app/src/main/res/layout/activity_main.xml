<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1C1C1E"
    android:padding="16dp">

    <TextView android:id="@+id/tvExpression"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="#8E8E93" android:textSize="24sp"
        android:gravity="end" android:paddingTop="32dp"/>

    <EditText android:id="@+id/tvDisplay"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"
        android:text="0" android:textColor="#FFFFFF"
        android:gravity="bottom|end"
        android:paddingBottom="8dp"
        android:background="@null"
        android:cursorVisible="true"
        android:inputType="textMultiLine|textNoSuggestions"
        android:scrollHorizontally="false"
        android:textCursorDrawable="@drawable/red_cursor" />

    <TextView android:id="@+id/tvPreview"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="#FF9F0A" android:textSize="32sp"
        android:gravity="end" android:paddingBottom="16dp" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="80dp" android:orientation="horizontal">
        <Button android:id="@+id/btnClear" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="AC" android:backgroundTint="#A5A5A5" android:textColor="#000" android:textSize="24sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
        <Button android:id="@+id/btnBackspace" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="⌫" android:backgroundTint="#A5A5A5" android:textColor="#000" android:textSize="24sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
        <Button android:id="@+id/btnPercent" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="%" android:backgroundTint="#A5A5A5" android:textColor="#000" android:textSize="24sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
        <Button android:id="@+id/btnDivide" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="÷" android:backgroundTint="#FF9F0A" android:textColor="#FFF" android:textSize="32sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="80dp" android:orientation="horizontal">
        <Button android:id="@+id/btn7" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="7" android:backgroundTint="#333333" android:textColor="#FFF" android:textSize="32sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
        <Button android:id="@+id/btn8" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="8" android:backgroundTint="#333333" android:textColor="#FFF" android:textSize="32sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
        <Button android:id="@+id/btn9" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="9" android:backgroundTint="#333333" android:textColor="#FFF" android:textSize="32sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
        <Button android:id="@+id/btnMultiply" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="×" android:backgroundTint="#FF9F0A" android:textColor="#FFF" android:textSize="32sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="80dp" android:orientation="horizontal">
        <Button android:id="@+id/btn4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="4" android:backgroundTint="#333333" android:textColor="#FFF" android:textSize="32sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
        <Button android:id="@+id/btn5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="5" android:backgroundTint="#333333" android:textColor="#FFF" android:textSize="32sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
        <Button android:id="@+id/btn6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="6" android:backgroundTint="#333333" android:textColor="#FFF" android:textSize="32sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
        <Button android:id="@+id/btnMinus" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="−" android:backgroundTint="#FF9F0A" android:textColor="#FFF" android:textSize="32sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="80dp" android:orientation="horizontal">
        <Button android:id="@+id/btn1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="1" android:backgroundTint="#333333" android:textColor="#FFF" android:textSize="32sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
        <Button android:id="@+id/btn2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="2" android:backgroundTint="#333333" android:textColor="#FFF" android:textSize="32sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
        <Button android:id="@+id/btn3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="3" android:backgroundTint="#333333" android:textColor="#FFF" android:textSize="32sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
        <Button android:id="@+id/btnPlus" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="+" android:backgroundTint="#FF9F0A" android:textColor="#FFF" android:textSize="32sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="80dp" android:orientation="horizontal">
        <Button android:id="@+id/btn0" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="2" android:text="0" android:backgroundTint="#333333" android:textColor="#FFF" android:textSize="32sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
        <Button android:id="@+id/btnDecimal" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="," android:backgroundTint="#333333" android:textColor="#FFF" android:textSize="32sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
        <Button android:id="@+id/btnEquals" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="=" android:backgroundTint="#FF9F0A" android:textColor="#FFF" android:textSize="32sp" android:layout_margin="4dp" android:insetBottom="0dp" android:insetTop="0dp"/>
    </LinearLayout>
</LinearLayout>
